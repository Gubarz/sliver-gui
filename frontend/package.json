{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./jsconfig.json",
    "lint": "eslint .",
    "deadcode": "knip --no-config-hints",
    "duplicates": "jscpd src --format svelte,javascript",
    "analyze": "npm run check && npm run lint && npm run deadcode && npm run duplicates"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "eslint": "^10.4.1",
    "eslint-plugin-svelte": "^3.19.0",
    "globals": "^17.6.0",
    "jscpd": "^5.0.7",
    "knip": "^6.16.1",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "typescript": "^6.0.3",
    "vite": "^6.4.3"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@fortawesome/fontawesome-free": "^6.7.2",
    "@xyflow/svelte": "^1.6.0",
    "ansi_up": "^6.0.6"
  }
}
